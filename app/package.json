    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.9.4",
    "react-toastify": "^11.0.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
