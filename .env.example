# ─── Compose profile — drives the active environment ─────────────────────────
# dev  → builds from source, file watching, port binding
# prod → pulls pre-built image from GHCR, Traefik labels, restart policy
COMPOSE_PROFILES=dev

# ─── App ──────────────────────────────────────────────────────────────────────
APP_PORT=3000
APP_DOMAIN=resume.chrysa.dev

# ─── Docker image (prod only) ─────────────────────────────────────────────────
IMAGE=ghcr.io/chrysa/resume
IMAGE_TAG=latest

# ─── GitHub — target repo for contact Issues ──────────────────────────────────
VITE_GITHUB_OWNER=chrysa
VITE_GITHUB_REPO=contact

# ─── Optional ─────────────────────────────────────────────────────────────────
# VITE_RATE_LIMIT_MAX=3
